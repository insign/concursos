<section class="settings-section" aria-labelledby="identity-title">
  <div>
    <p class="eyebrow">Perfil público</p>
    <h1 id="identity-title">Alias de sincronização</h1>
    <p>
      O alias separa seus dados neste dispositivo e compõe IDs públicos na API. Ele não é conta, senha nem proteção de privacidade.
    </p>
  </div>

  <form class="identity-form" data-identity-form>
    <p>Alias atual: <strong data-current-alias>Nenhum</strong></p>
    <label for="profile-alias">Novo alias</label>
    <input
      id="profile-alias"
      name="alias"
      type="text"
      maxlength="32"
      pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
      autocomplete="username"
      aria-describedby="alias-help alias-warning"
      required
    />
    <p id="alias-help" class="field-help">Use letras minúsculas, números e hífens. O valor não será normalizado.</p>
    <p id="alias-warning" class="warning-note">
      Prefira algo menos previsível que seu nome. Qualquer pessoa que descubra o ID poderá ler, alterar ou apagar os dados remotos.
    </p>

    <label class="danger-option" data-discard-option>
      <input type="checkbox" name="discardPending" />
      Descartar alterações locais pendentes do alias atual se a sincronização não puder concluí-las
    </label>

    <div class="form-actions">
      <button class="button" type="submit">Usar este alias</button>
      <p data-identity-status aria-live="polite"></p>
    </div>
  </form>
</section>

<script>
  import {
    changeActiveAlias,
    getActiveAlias,
    isAliasEasyToGuess,
    PendingProfileChangeError,
  } from '../lib/identity';
  import {
    prepareCompleteProfileAlias,
    requestCompleteProfileSync,
  } from '../lib/simulados-profile-sync';

  document.querySelectorAll<HTMLFormElement>('[data-identity-form]').forEach((form) => {
    const aliasInput = form.elements.namedItem('alias') as HTMLInputElement;
    const discardInput = form.elements.namedItem('discardPending') as HTMLInputElement;
    const status = form.querySelector<HTMLElement>('[data-identity-status]')!;
    const current = form.querySelector<HTMLElement>('[data-current-alias]')!;
    const discardOption = form.querySelector<HTMLElement>('[data-discard-option]')!;
    let linking = false;

    const activeAlias = getActiveAlias();
    current.textContent = activeAlias ?? 'Nenhum';
    discardOption.hidden = activeAlias === null;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (linking) return;
      linking = true;
      form.querySelectorAll<HTMLInputElement | HTMLButtonElement>('input, button').forEach((control) => {
        control.disabled = true;
      });
      status.textContent = 'Buscando e validando os dados deste alias...';
      let reloadScheduled = false;

      try {
        const alias = aliasInput.value;
        const changed = await changeActiveAlias(alias, {
          discardPending: discardInput.checked,
          synchronize: requestCompleteProfileSync,
          prepare: (profileId) =>
            prepareCompleteProfileAlias(profileId, {
              onPreflightComplete: ({ remoteDocumentCount }) => {
                if (remoteDocumentCount > 0) {
                  status.textContent = `Alias encontrado com ${remoteDocumentCount} documento${remoteDocumentCount === 1 ? '' : 's'} remoto${remoteDocumentCount === 1 ? '' : 's'}.`;
                  const confirmed = window.confirm(
                    `Este alias já possui ${remoteDocumentCount} documento${remoteDocumentCount === 1 ? '' : 's'} remoto${remoteDocumentCount === 1 ? '' : 's'}. Deseja vincular e usar esses dados neste dispositivo?`,
                  );
                  if (!confirmed) {
                    throw new Error(
                      getActiveAlias()
                        ? 'Vinculação cancelada; o alias atual foi preservado.'
                        : 'Vinculação cancelada; nenhum alias foi ativado.',
                    );
                  }
                }
                status.textContent =
                  remoteDocumentCount > 0
                    ? 'Sincronizando o perfil encontrado...'
                    : 'Preparando um novo perfil...';
              },
            }),
        });
        if (!changed) {
          status.textContent = 'Este alias já está ativo.';
          return;
        }
        status.textContent = isAliasEasyToGuess(alias)
          ? 'Alias salvo. Considere usar um valor menos previsível.'
          : 'Alias salvo neste dispositivo.';
        reloadScheduled = true;
        window.setTimeout(() => window.location.reload(), 250);
      } catch (error) {
        if (error instanceof PendingProfileChangeError) {
          status.textContent = 'Há alterações pendentes. Sincronize ou confirme o descarte antes de trocar.';
        } else {
          status.textContent = error instanceof Error ? error.message : 'Não foi possível alterar o alias.';
        }
      } finally {
        if (!reloadScheduled) {
          linking = false;
          form.querySelectorAll<HTMLInputElement | HTMLButtonElement>('input, button').forEach((control) => {
            control.disabled = false;
          });
        }
      }
    });
  });
</script>

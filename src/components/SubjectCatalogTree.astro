---
import ProgressSummary from './ProgressSummary.astro';
import type { CatalogContest, CatalogTreeNode } from '../lib/catalog';

interface Props {
  contest: CatalogContest;
  nodes: CatalogTreeNode[];
  depth?: number;
}

const { contest, nodes, depth = 0 } = Astro.props;
const Heading = `h${Math.min(depth + 2, 6)}` as 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
---

<ol class="subject-tree" data-depth={depth}>
  {
    nodes.map((node) =>
      node.kind === 'subject' ? (
        <li class="subject-item">
          <article class="subject-card">
            <a class="subject-card-title" href={`/concursos/${contest.slug}/${node.slug}/`}>{node.title}</a>
            <div class="subject-card-meta">
              <a
                class="subject-reading-link"
                href={`/concursos/${contest.slug}/${node.slug}/leitura/`}
                aria-label={`Ler ${node.title} sem distrações`}
              >
                <svg
                  class="subject-reading-icon"
                  viewBox="0 0 24 24"
                  width="1em"
                  height="1em"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="4" y="3" width="16" height="18" rx="2" />
                  <path d="M8 8h8M8 12h8M8 16h5" />
                </svg>
              </a>
              <ProgressSummary
                contestStorageId={contest.storageId}
                subjectStorageId={node.storageId}
                questionSetRevision={node.questionSetEntry.data.questionSetRevision}
              />
            </div>
          </article>
        </li>
      ) : (
        <li class="subject-group">
          <details class="subject-group-section" open data-group-id={node.id}>
            <summary class="subject-group-summary">
              <Heading class="subject-group-title">{node.title}</Heading>
            </summary>
            {node.description && <p class="subject-group-description">{node.description}</p>}
            <Astro.self contest={contest} nodes={node.children} depth={depth + 1} />
          </details>
        </li>
      ),
    )
  }
</ol>

<script>
  import {
    CATALOG_GROUPS_STORAGE_KEY,
    parseCollapsedGroups,
    serializeCollapsedGroups,
  } from '../lib/catalog-groups';

  const groups = Array.from(
    document.querySelectorAll<HTMLDetailsElement>('details.subject-group-section[data-group-id]'),
  );

  if (groups.length > 0) {
    let collapsed = new Set<string>();
    try {
      collapsed = parseCollapsedGroups(localStorage.getItem(CATALOG_GROUPS_STORAGE_KEY));
    } catch {
      collapsed = new Set();
    }

    // Restaura o estado salvo antes de registrar os ouvintes de alternância.
    for (const details of groups) {
      const id = details.dataset.groupId;
      if (id) details.open = !collapsed.has(id);
    }

    const persist = () => {
      try {
        localStorage.setItem(CATALOG_GROUPS_STORAGE_KEY, serializeCollapsedGroups(collapsed));
      } catch {
        // Sem localStorage gravável (modo privado, quota): apenas não persiste.
      }
    };

    for (const details of groups) {
      details.addEventListener('toggle', () => {
        const id = details.dataset.groupId;
        if (!id) return;
        if (details.open) collapsed.delete(id);
        else collapsed.add(id);
        persist();
      });
    }
  }
</script>

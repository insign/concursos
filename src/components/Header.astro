---
import SyncStatus from './SyncStatus.astro';
import OfflineStatus from './OfflineStatus.astro';
import PwaInstallButton from './PwaInstallButton.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header print-hidden">
  <a class="site-mark" href="/" aria-label="Concursos, página inicial">
    <span aria-hidden="true">C</span>
    <strong>Concursos</strong>
  </a>
  <nav aria-label="Navegação principal">
    <a href="/">Catálogo</a>
    <a href="/simulados/">Simulados</a>
    <a href="/configuracoes/">Configurações</a>
  </nav>
  <div class="pwa-controls">
    <ThemeToggle />
    <OfflineStatus />
    <PwaInstallButton />
  </div>
  <SyncStatus />
</header>

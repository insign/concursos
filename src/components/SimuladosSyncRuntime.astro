<script>
  import { getActiveAlias } from '../lib/identity';
  import { requestCompleteProfileSync } from '../lib/simulados-profile-sync';

  if (location.pathname.startsWith('/simulados/')) {
    let running = false;
    let rerun = false;

    const synchronize = async () => {
      const alias = getActiveAlias();
      if (!alias || !navigator.onLine) return;
      if (running) {
        rerun = true;
        return;
      }
      running = true;
      try {
        await requestCompleteProfileSync(alias);
        window.dispatchEvent(
          new CustomEvent('concursos:simulados-synced', { detail: { profileId: alias } }),
        );
        // A página usa popstate para recarregar um ?id que só passou a existir após o sync remoto.
        if (new URLSearchParams(location.search).has('id')) {
          window.dispatchEvent(new PopStateEvent('popstate'));
        }
      } finally {
        running = false;
        if (rerun) {
          rerun = false;
          void synchronize();
        }
      }
    };

    window.addEventListener('concursos:simulados-updated', () => void synchronize());
    window.addEventListener('online', () => void synchronize());
    window.addEventListener('focus', () => void synchronize());
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') void synchronize();
    });
    void synchronize();
  }
</script>

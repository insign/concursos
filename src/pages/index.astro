---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCatalog } from '../lib/catalog';

const title = 'Concursos';
const { contests } = await getCatalog();
---

<BaseLayout title={title}>
  <main class="catalog-shell">
    <header class="catalog-intro">
      <p class="eyebrow">Biblioteca de estudo</p>
      <h1>{title}</h1>
      <p>Conteúdo versionado, revisão objetiva e questões para acompanhar sua preparação.</p>
    </header>

    {contests.length > 0 ? (
      <ul class="catalog-grid">
        {contests.map((contest) => (
          <li>
            <article class="catalog-card">
              <a href={`/concursos/${contest.slug}/`}>{contest.title}</a>
              <p>{contest.description}</p>
              <p>{contest.subjects.length} {contest.subjects.length === 1 ? 'assunto' : 'assuntos'}</p>
            </article>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Nenhum concurso foi publicado.</p>
    )}
  </main>
</BaseLayout>

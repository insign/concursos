---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada" description="A página solicitada não existe no portal Concursos.">
  <main class="offline-shell">
    <p class="eyebrow">Erro 404</p>
    <h1>Página não encontrada</h1>
    <p>O endereço pode ter mudado ou o conteúdo ainda não foi publicado.</p>
    <a class="button" href="/">Voltar ao catálogo</a>
  </main>
</BaseLayout>

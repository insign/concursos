---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OfflineContestButton from '../../../components/OfflineContestButton.astro';
import SubjectCatalogTree from '../../../components/SubjectCatalogTree.astro';
import { getCatalog, type CatalogContest } from '../../../lib/catalog';

interface Props {
  contest: CatalogContest;
}

export async function getStaticPaths() {
  const { contests } = await getCatalog();
  return contests.map((contest) => ({ params: { concurso: contest.slug }, props: { contest } }));
}

const { contest } = Astro.props;
---

<BaseLayout title={contest.title} description={contest.description}>
  <main class="contest-shell">
    <nav class="breadcrumbs" aria-label="Caminho da página">
      <a href="/">Concursos</a>
      <span aria-hidden="true">/</span>
      <span>{contest.title}</span>
    </nav>

    <header class="contest-intro">
      <p class="eyebrow">Concurso</p>
      <h1>{contest.title}</h1>
      <p>{contest.description}</p>
      <p><a href={`/simulados/?concurso=${contest.storageId}`}>Gerar simulado deste concurso</a></p>
    </header>

    <OfflineContestButton contestStorageId={contest.storageId} contestTitle={contest.title} />

    {contest.subjects.length > 0 ? (
      <SubjectCatalogTree contest={contest} nodes={contest.children} />
    ) : (
      <p class="empty-state">Este concurso ainda não possui assuntos publicados.</p>
    )}
  </main>
</BaseLayout>

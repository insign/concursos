---
import { render } from 'astro:content';
import MermaidRuntime from '../../../../components/MermaidRuntime.astro';
import StudiedToggle from '../../../../components/StudiedToggle.astro';
import StudyLayout from '../../../../layouts/StudyLayout.astro';
import { getSubjectStaticPaths, type CatalogContest, type CatalogSubject } from '../../../../lib/catalog';

interface Props {
  contest: CatalogContest;
  subject: CatalogSubject;
}

export const getStaticPaths = getSubjectStaticPaths;

const { contest, subject } = Astro.props;
const { Content } = await render(subject.contentEntry);
const hasMermaid = subject.contentEntry.body?.includes('```mermaid') ?? false;
---

<StudyLayout contest={contest} subject={subject} active="content">
  <div class="subject-actions print-hidden">
    <StudiedToggle contestStorageId={contest.storageId} subjectStorageId={subject.storageId} />
    <a class="reading-entry-link" href={`/concursos/${contest.slug}/${subject.slug}/leitura/`}>
      Ler sem distrações
    </a>
  </div>
  <article>
    <Content />
  </article>
  {hasMermaid && <MermaidRuntime />}
</StudyLayout>

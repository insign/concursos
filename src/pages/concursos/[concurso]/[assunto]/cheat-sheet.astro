---
import { render } from 'astro:content';
import MermaidRuntime from '../../../../components/MermaidRuntime.astro';
import PrintButton from '../../../../components/PrintButton.astro';
import StudyLayout from '../../../../layouts/StudyLayout.astro';
import { getSubjectStaticPaths, type CatalogContest, type CatalogSubject } from '../../../../lib/catalog';

interface Props {
  contest: CatalogContest;
  subject: CatalogSubject;
}

export const getStaticPaths = getSubjectStaticPaths;

const { contest, subject } = Astro.props;
const { Content } = await render(subject.cheatSheetEntry);
const hasMermaid = subject.cheatSheetEntry.body?.includes('```mermaid') ?? false;
---

<StudyLayout contest={contest} subject={subject} active="cheat-sheet">
  <PrintButton />
  <article class="cheat-sheet-content">
    <Content />
  </article>
  {hasMermaid && <MermaidRuntime />}
</StudyLayout>

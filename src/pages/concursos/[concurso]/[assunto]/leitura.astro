---
import { render } from 'astro:content';
import MermaidRuntime from '../../../../components/MermaidRuntime.astro';
import ReadingLayout from '../../../../layouts/ReadingLayout.astro';
import { getSubjectStaticPaths, type CatalogContest, type CatalogSubject } from '../../../../lib/catalog';

interface Props {
  contest: CatalogContest;
  subject: CatalogSubject;
}

export const getStaticPaths = getSubjectStaticPaths;

const { contest, subject } = Astro.props;
const { Content } = await render(subject.contentEntry);
const body = subject.contentEntry.body ?? '';
const hasMermaid = body.includes('```mermaid');
// Se o conteúdo já começa com um h1, ele é o cabeçalho principal; senão, o layout
// adiciona o título do assunto como h1.
const contentHasH1 = /^\s*#\s/.test(body);
---

<ReadingLayout contest={contest} subject={subject} showTitle={!contentHasH1}>
  <Content />
  {hasMermaid && <MermaidRuntime />}
</ReadingLayout>
